{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env"
  ],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_SOCKET_URL",
    "NEXT_PUBLIC_CHECKMATE_BET_ADDRESS",
    "NEXT_PUBLIC_CHAIN_ID",
    "NEXT_PUBLIC_MOCK_CHAIN",
    "NEXT_PUBLIC_ENABLE_ONCHAIN_BETS",
    "PORT",
    "DATABASE_URL",
    "MOCK_CHAIN",
    "RPC_BASE_SEPOLIA",
    "RPC_ETHEREUM_SEPOLIA",
    "PRIVATE_KEY",
    "TREASURY_ADDRESS",
    "CONTRACT_OWNER_ADDRESS",
    "ADMIN_API_KEY",
    "JWT_SECRET",
    "GROQ_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    }
  }
}
