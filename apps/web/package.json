{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x",
    "pnpm": "9.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "(node_modules/.bin/prisma generate --schema prisma/schema.prisma || ../../node_modules/.bin/prisma generate --schema prisma/schema.prisma) && (node_modules/.bin/prisma db push --schema prisma/schema.prisma --accept-data-loss || ../../node_modules/.bin/prisma db push --schema prisma/schema.prisma --accept-data-loss) && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "node_modules/.bin/prisma generate --schema prisma/schema.prisma || ../../node_modules/.bin/prisma generate --schema prisma/schema.prisma",
    "prisma:push": "node_modules/.bin/prisma db push --schema prisma/schema.prisma || ../../node_modules/.bin/prisma db push --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^4.5.2",
    "@tanstack/react-query": "^5.28.9",
    "socket.io-client": "^4.7.5",
    "framer-motion": "^11.0.24",
    "chess.js": "^1.0.0-beta.6",
    "lucide-react": "^0.359.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.2",
    "@prisma/client": "^5.14.0",
    "shared": "workspace:*",
    "wagmi": "^2.10.4",
    "viem": "^2.13.5",
    "connectkit": "^1.8.2"
  },
  "onlyBuiltDependencies": [
    "@prisma/client",
    "prisma",
    "@prisma/engines",
    "esbuild",
    "keccak",
    "secp256k1",
    "sharp",
    "bufferutil",
    "utf-8-validate",
    "styled-components"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^5.14.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
